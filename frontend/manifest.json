{
  "manifest_version": 3,
  "name": "Privacy Guard",
  "version": "1.0",
  "description": "Web Security Extension - Melindungi dari website berbahaya",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation", "tabs"],
  "host_permissions": ["<all_urls>", "http://localhost:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "asset/icon16.png",
      "48": "asset/icon48.png",
      "128": "asset/icon128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["components/*", "pages/*", "asset/*", "src/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "asset/icon16.png",
    "48": "asset/icon48.png",
    "128": "asset/icon128.png"
  }
}
